# =============================================================
# NutriPerformance Clinical — Backend Environment Variables
# Copie para .env e preencha com valores reais
# NUNCA commite o arquivo .env no git
# =============================================================

# Banco de dados
DATABASE_URL=postgresql://postgres:senha@localhost:5432/nutriperformance

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google Gemini API (motor de IA clínica) — OBRIGATÓRIO
# Obter em: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Mercado Pago (opcional)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...

# JWT
JWT_SECRET=gere-com-openssl-rand-base64-64
JWT_EXPIRY=7d

# Redis
REDIS_URL=redis://localhost:6379

# Criptografia de dados sensíveis (LGPD)
# Gerar com: openssl rand -hex 32
ENCRYPTION_KEY=sua_chave_de_32_bytes_em_hex_aqui
# Salt para hash de CPF — gerar com: openssl rand -hex 16
CPF_SALT=seu_salt_aqui

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Supabase Storage
SUPABASE_STORAGE_BUCKET=nutriperformance-docs

# Sentry (monitoramento — opcional em dev)
SENTRY_DSN=https://xxx@sentry.io/xxx
