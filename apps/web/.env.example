# =============================================================
# NutriPerformance Clinical — Frontend Environment Variables
# Copie para .env.local e preencha com valores reais
# =============================================================

# API Backend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase (somente chave pública — NUNCA service role key no frontend)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe (chave publicável — pode ser exposta)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NutriPerformance Clinical
