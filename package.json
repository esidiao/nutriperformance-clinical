{
  "name": "nutri-performance-clinical",
  "version": "1.0.0",
  "private": true,
  "description": "NutriPerformance Clinical — SaaS para Nutricionistas e Profissionais de Educação Física",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "cd apps/api && npx typeorm migration:run",
    "db:seed": "psql $DATABASE_URL < docs/seed-data.sql"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
